# -----------------------------------------------------------------------------
# Concave CMS — local development environment
# Copy to `.env.local` and fill in values. Never commit real secrets.
# -----------------------------------------------------------------------------

# App environment label shown in the UI banner (development | staging | production)
VITE_APP_ENV=development

# Convex deployment URL (from `npx convex dev` output)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Convex HTTP actions / Better Auth site URL (local dev: site proxy port = convex port + 1)
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Better Auth (TanStack Start server)
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-at-least-16-random-characters
BETTER_AUTH_URL=http://localhost:3000

# Convex / Better Auth site URL (must match your app origin)
SITE_URL=http://localhost:3000

# Optional: Google OAuth (leave empty to disable social sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: preview URL signing (Phase 5+)
PREVIEW_SECRET=replace-with-at-least-16-random-characters

# E2E tests only — set in CI / Playwright webServer (never use in production)
# E2E_TEST_SECRET=replace-with-at-least-16-random-characters

# Cloud agents / CI: use anonymous Convex agent mode to avoid touching your dev deployment
# CONVEX_AGENT_MODE=anonymous
