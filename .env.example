# -----------------------------------------------------------------------------
# Concave CMS — environment template
# Copy to `.env.local` (local dev) or `.env` (Docker Compose).
# Never commit real secrets.
# -----------------------------------------------------------------------------

# --- Frontend (build-time: VITE_* are embedded at `bun run build` / Docker build) ---

# App environment label shown in the UI banner (development | staging | production)
VITE_APP_ENV=development

# Convex deployment URL (from `npx convex dev` or Convex dashboard)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Convex HTTP actions / Better Auth site URL (local dev: convex port + 1)
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# --- Server runtime (TanStack Start / Better Auth) ---

# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-at-least-16-random-characters
BETTER_AUTH_URL=http://localhost:3000

# Must match the public origin users use to open the admin app
SITE_URL=http://localhost:3000

# Optional: Google OAuth (leave empty to disable social sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: preview URL signing
PREVIEW_SECRET=replace-with-at-least-16-random-characters

# --- Docker Compose (optional) ---

# Host port mapped to the web container (default 3000)
PORT=3000

# --- Convex CLI / CI (not required for local `convex dev`) ---

# Deploy key for `npx convex deploy` in CI/CD
# CONVEX_DEPLOY_KEY=

# Deployment URL for backup/restore scripts
# CONVEX_URL=https://your-deployment.convex.cloud

# --- E2E tests only (CI / Playwright webServer — never use in production) ---

# E2E_TEST_SECRET=replace-with-at-least-16-random-characters

# Cloud agents / CI: isolated Convex environment
# CONVEX_AGENT_MODE=anonymous
